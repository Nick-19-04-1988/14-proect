{
    "name": "name",
    "version": "1.0.0",
    "description": "",
    "dependencies": {
        "express": "^4.18.2",
        "cors": "^2.8.5"
    },
    "devDependencies": {
        "autoprefixer": "^10.4.13",
        "browser-sync": "^2.27.11",
        "del": "^5.1.0",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.1",
        "gulp": "^4.0.2",
        "gulp-cache": "^1.1.3",
        "gulp-cheerio": "^1.0.0",
        "gulp-clean-css": "^4.3.0",
        "gulp-group-css-media-queries": "^1.2.2",
        "gulp-htmlmin": "^5.0.1",
        "gulp-imagemin": "^7.1.0",
        "gulp-newer": "^1.4.0",
        "gulp-plumber": "^1.2.1",
        "gulp-postcss": "^9.0.1",
        "gulp-rename": "^2.0.0",
        "gulp-replace": "^1.1.4",
        "gulp-sass": "^5.1.0",
        "gulp-sourcemaps": "^3.0.0",
        "gulp-svgstore": "^9.0.0",
        "gulp-terser": "^2.1.0",
        "husky": "^8.0.3",
        "jsdom": "^29.1.1",
        "lint-staged": "^14.0.0",
        "node-sass": "^8.0.0",
        "postcss": "^8.4.21",
        "prettier": "^3.0.0",
        "sass": "^1.58.0",
        "stylelint": "^15.2.0",
        "stylelint-config-standard-scss": "^7.0.1",
        "vitest": "^1.4.0"
    },
    "scripts": {
        "stylelint": "npx stylelint \"app/sass/**/*.scss\"",
        "lint:css": "npx stylelint \"app/sass/**/*.scss\"",
        "lint:js": "npx eslint \"app/js/**/*.js\"",
        "lint": "npm run lint:css && npm run lint:js",
        "format": "npx prettier --write \"app/**/*.{js,scss,html,json,md}\"",
        "test:js": "npx vitest run",
        "test": "npm run test:js",
        "build": "gulp build",
        "dev": "gulp",
        "start": "gulp",
        "server": "node server.js",
        "dev:full": "npm run build && npm run server",
        "prepare": "npx husky install"
    },
    "lint-staged": {
        "app/js/**/*.js": [
            "npx eslint --fix"
        ],
        "app/sass/**/*.scss": [
            "npx stylelint --fix"
        ],
        "app/**/*.html": [
            "npx prettier --write"
        ]
    },
    "browserslist": [
        "last 2 versions",
        "IE 11",
        "Firefox ESR"
    ]
}

